{
  "expo": {
    "name": "Perfectly Flawed Leadership",
    "slug": "PerfectlyFlawed",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/web-app-manifest-192x192.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/web-app-manifest-192x192.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.perfectlyflawedleadership.app",
      "supportsTablet": true
    },
    "android": {
      "package": "com.perfectlyflawedleadership.app",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/web-app-manifest-192x192.png"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-web-browser"
    ]
  }
}
