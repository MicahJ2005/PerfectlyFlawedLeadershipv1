rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /savedDevotions/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /leadershipSessions/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── Push Subscriptions ────────────────────────────────────────────────────
    match /pushSubscriptions/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Verses ────────────────────────────────────────────────────────────────
    match /verses/{verseId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null; // allows one-time client seed
      allow update, delete: if false;
    }

    // ── Public Prayer Wall ────────────────────────────────────────────────────
    match /prayerRequests/{prayerId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      // Owner can deactivate; any member can toggle prayedBy/hearts
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // ── Private Prayer Groups ─────────────────────────────────────────────────
    match /privateGroups/{groupId} {
      // Any signed-in user can create a group
      allow create: if request.auth != null;

      // Only members can read the group
      allow read: if request.auth != null &&
                     request.auth.uid in resource.data.members;

      // Members can update (join/leave, memberNames field)
      allow update: if request.auth != null &&
                       (request.auth.uid in resource.data.members ||
                        request.auth.uid in request.resource.data.members);

      allow delete: if false;

      // Private group prayers — members only
      match /prayers/{prayerId} {
        allow read, write: if request.auth != null &&
                              request.auth.uid in get(/databases/$(database)/documents/privateGroups/$(groupId)).data.members;
      }
    }
  }
}
